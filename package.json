{
  "name": "dc-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build && npx @cloudflare/next-on-pages",
    "start": "next start",
    "lint": "next lint",
    "pages:dev": "wrangler pages dev",
    "pages:deploy": "wrangler pages deploy",
    "db:migrate:local": "wrangler d1 migrations apply dc-league --local",
    "db:migrate:remote": "wrangler d1 migrations apply dc-league --remote"
  },
  "dependencies": {
    "@cloudflare/next-on-pages": "^1.13.7",
    "lucide-react": "^0.454.0",
    "next": "^15.1.0",
    "react": "^18",
    "react-dom": "^18"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241205.0",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.0.1",
    "eslint": "^8",
    "eslint-config-next": "^15.1.0",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5",
    "wrangler": "^3.99.0"
  }
}
