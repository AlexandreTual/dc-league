# ── Supabase ───────────────────────────────────────────────────
# Disponible dans ton dashboard Supabase > Settings > API

# URL de ton projet Supabase (visible publiquement, ok côté client)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Clé anon (visible publiquement, lecture seule avec RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6...

# Clé service_role (SECRÈTE — ne jamais exposer côté client)
# Utilisée uniquement par les API routes Next.js côté serveur
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6...

# ── Admin ──────────────────────────────────────────────────────
# Mot de passe pour accéder au dashboard /admin
ADMIN_PASSWORD=ton-mot-de-passe-secret
